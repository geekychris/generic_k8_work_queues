FROM golang:1.26-alpine AS builder

RUN apk --no-cache add ca-certificates

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o sidecar ./cmd/sidecar

FROM alpine:3.20

RUN apk --no-cache add ca-certificates

COPY --from=builder /app/sidecar /usr/local/bin/sidecar

EXPOSE 8081
ENTRYPOINT ["sidecar"]
